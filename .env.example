# Optional provider credentials for ai-assisted extraction and runtime execution.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenCode Go (https://opencode.ai/docs/go/) — beta provider.
# Uses the OpenAI-compatible Zen endpoint at https://opencode.ai/zen/go/v1/chat/completions.
# Models: try the namespaced form first, e.g. `opencode-go/kimi-k2.6`.
#   If the endpoint aborts the connection, also try the bare form: `kimi-k2.6`.
# Auth: defaults to `Authorization: Bearer <key>`. If the endpoint returns 401 or aborts,
#   try OPENCODE_GO_AUTH_HEADER_MODE=x-api-key to send `X-Api-Key: <key>` instead.
# Troubleshooting connection aborts:
#   1. Run `ruleprobe doctor` — verifies key visibility, dist, and CLI tools.
#   2. Try the namespaced model form: OPENCODE_GO_MODEL=opencode-go/kimi-k2.6
#   3. Try the bare model form:       OPENCODE_GO_MODEL=kimi-k2.6
#   4. Verify plan entitlement at https://opencode.ai — the model must be on your plan.
#   5. Try OPENCODE_GO_AUTH_HEADER_MODE=x-api-key if bearer auth is rejected.
OPENCODE_GO_API_KEY=
OPENCODE_GO_MODEL=
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
OPENCODE_GO_AUTH_HEADER_MODE=bearer
OPENCODE_GO_TIMEOUT_MS=

# Optional runtime tuning.
RULEPROBE_PROVIDER_TIMEOUT_MS=60000
RULEPROBE_ACTION_TIMEOUT_MS=3000

# CI/comparison examples usually keep real-provider comparison non-blocking.
# Mock and dry-run providers do not require credentials.
